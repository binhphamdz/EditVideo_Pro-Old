{
  "manifest_version": 3,
  "name": "EditVideo Pro TikTok Agent",
  "version": "0.2.0",
  "description": "Agent extension for EditVideo Pro Tab 13.",
  "permissions": ["storage", "tabs", "scripting", "alarms", "debugger"],
  "host_permissions": ["https://shop.tiktok.com/*", "https://www.tiktok.com/*", "ws://127.0.0.1:*/*", "ws://localhost:*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://shop.tiktok.com/*", "https://www.tiktok.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
